# ── LLM Provider (at least one required) ─────────────────────────────────────
# The system will automatically pick the first one that is set.
ANTHROPIC_API_KEY=your-anthropic-key-here
# OPENAI_API_KEY=your-openai-key-here
# GOOGLE_API_KEY=your-google-key-here
# GROQ_API_KEY=your-groq-key-here

# ── Embeddings ────────────────────────────────────────────────────────────────
# Default: uses free local HuggingFace sentence-transformers model.
# Set to "true" to use OpenAI's text-embedding-3-small instead (requires OPENAI_API_KEY).
# USE_OPENAI_EMBEDDINGS=false

# ── Optional: LangSmith tracing ───────────────────────────────────────────────
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your-langsmith-key-here
# LANGCHAIN_PROJECT=task-02-multi-agent-rag
